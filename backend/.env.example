# Backend server
PORT=8000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_replace_me

# CVCRM API
CVCRM_EMAIL=seu-email@empresa.com
CVCRM_TOKEN=replace_me
CVCRM_BASE_URL=https://vca.cvcrm.com.br/api/v1/comercial/reservas

# CVCRM LOTEAR API (opcional)
CVCRM_LOTEAR_TOKEN=replace_me
CVCRM_LOTEAR_BASE_URL=https://vcalotear.cvcrm.com.br/api/v1/comercial/reservas

# Admin access
# Credenciais do admin são armazenadas na tabela 'administradores' do Supabase
# Execute o script db/migrations/003_administradores_schema.sql no SQL Editor do Supabase para criar a tabela
# Padrão: username: admin, senha: Admin@2026 (pode ser alterada)
ADMIN_AUTH_SECRET=replace_me_with_strong_random_secret
MANAGER_TOKEN_TTL_SECONDS=1800
ANALYST_AUTH_SECRET=replace_me_with_strong_random_secret
ANALYST_TOKEN_TTL_SECONDS=43200

# CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:5173

# Sync worker interval in seconds
SYNC_INTERVAL_SECONDS=25

# SMTP (password reset)
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=usuario@dominio.com
SMTP_PASS=replace_me
SMTP_FROM=nao-responda@dominio.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# URL pública do frontend para links de redefinição
FRONTEND_URL=https://seu-frontend.com
RESET_TOKEN_TTL_MINUTES=60
